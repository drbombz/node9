{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 42, // Waybar height (to be removed for auto height)
    "margin": "15, 10, 10, 10",
    // "gtk-layer-shell": "false",
    
    // Choose the order of the modules
    "modules-left": [
        "hyprland/workspaces", 
        "custom/scratchpad",
        "custom/sep1",
        "hyprland/window",
        ],

    "modules-center": [],
   
    "modules-right": [ 
        "network", 
        "bluetooth",
        "battery",
        "memory", 
        "backlight",
        "pulseaudio", 
        "custom/notification",
        "clock"
        ],

    "hyprland/submap": {
        "format": "ΎΒΦΎΕΖ {}",
	   "max-length": 30,
	   "tooltip": false
    },

    "hyprland/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": " {icon} ",
        "format-icons": {
             "1": "≤░γσ",
             "2": "≤░ζ┤",
             "3": "≤░Λι",
             "4": "<span font='14'>≤░λγ</span>",
             "urgent": "ΎΒς",
             "focused": "ΎΗΤ",
             "default": "ΎΛΤ"
        },
        "persistent-workspaces": { "*": 4 }
    },
    "custom/sep1": {
        "format": "ΌΙΨΌΙΨ"
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 65,
        "icon": false,
        "rewrite": {
            "(.*) - Sublime Text(.*)": "$1",
            "(.*) έΑΦ Mozilla Firefox": "$1" 
        },
        "tooltip": false
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "ΎΘτ {essid}",
        "format-ethernet": "Ύδ┐",
        "format-linked": "ΎηΨ",
        "format-disconnected": "έγι",
        "tooltip": true,
        "tooltip-format": "ΎΘτ {essid} ({signalStrength}%)", 
        //"format-alt": "ΎΘτ {essid} ({signalStrength}%)",
        "on-click": "nm-connection-editor"
    },
    "bluetooth": {
        "format": "ΎΛΦ",
        "format-disabled": "≤░Γ▓",
        "format-off": "≤░Γ▓",
        //"format-connected": "ΎΛΦ {num_connections}",
        "format-connected": "ΎΛΦ {device_alias}",
        //"tooltip-format": "{controller_address} {status}\n\n{num_connections} connected",
        //"tooltip-format-disabled": "{status}",
        //"tooltip-format-connected": "{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        //"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        //"format-connected-battery": "ΎΛΦ {device_alias} {device_battery_percentage}%",
        //"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "exec blueman-manager",
        "on-click-middle": "exec bluetoothctl power off",
	    "on-click-right": "exec bluetoothctl power on"
    },
    
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "≤░ΓΖ   {capacity}%",
        "format-plugged": "ΎΘο  {capacity}%",
        "format-alt": "{capacity}% {time}",
        //"format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
        "format-icons": ["≤░Β║", "≤░Β╝", "≤░Β╛", "≤░ΓΑ", "≤░Β╣"]
    },
    
    "memory": {
        "format": "<span font='24px'>≤░Ξδ</span>   {}%"
    },
    
    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon}  {percent}% ",
        "format-icons": ["ΎΗΖ"]
    },
    
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        //"format-alt": "{icon}",
        //"format-alt-click": "click-right",
        "format-muted": "Ύγσ",
        "format-icons": {
            "headphones": "ΎΑξ",
            "handsfree": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "scroll-step": 10,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "tooltip": false
    },
    
    "clock": {
        // "timezone": "America/New_York",
        "format": "{:%B %d, %Y %R}",
        //"format": "ΎΑΩ",
        "format-alt": "{:%a %d %b w%V %H:%M}",
        "tooltip-format": "<span color='#b88f74'><tt><small>{calendar}</small></tt></span>",
        "calendar": {
            "mode-mon-col"      : 4,
            "weeks-pos"         : "left",
            "on-scroll"         : 1,
            "on-click-right"    : "mode",
            "format": {
                "months":    "<span color='#FF8542'><b>{}</b></span>",
                "weeks":    "<span color='#604da7'><b>{}</b></span>",
                "weekdays": "<span color='#FEf2EC'><b>{}</b></span>",
                "today":    "<span color='#21a4df'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right"    : "mode",
            "on-scroll-up"      : "shift_up",
            "on-scroll-down"      : "shift_down"
        },
        "interval": 10
    },
    "custom/layout": {
        "tooltip": false,
        "exec": "swaymsg -mrt subscribe '[\"input\"]' | jq -r --unbuffered \"select(.change == \\\"xkb_layout\\\") | .input | select(.type == \\\"keyboard\\\") | .xkb_active_layout_name | .[0:2]\""
    },
    "custom/zypper": {
        "format": "{} ΎΗΘ",
        "interval": 3600,
        "exec": "zypper lu | grep 'v |' | wc -l; echo 'packages to update'",
        "exec-if": "exit 0",
        "on-click": "exec alacritty -e sudo sh -c 'zypper ref; zypper dup; pkill -SIGRTMIN+8 waybar'",
        "signal": 8
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        } 
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },

    "cpu": {
        "format": "{usage}% ΎΜδ",
        "tooltip": false
    },

    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["Ύζτ", "ΎΜΚ", "Ύζσ"]
    },


    "battery#bat2": {
        "bat": "BAT2"
    },

    "custom/scratchpad": {
        "format-text": "{}",
        "return-type": "json",
        "interval": 3,
        "exec": "/usr/share/openSUSEway/helpers/scratchpad-indicator.sh 2> /dev/null",
        "exec-if": "exit 0",
        "on-click": "swaymsg 'scratchpad show'",
        "on-click-right": "swaymsg 'move scratchpad'"
    },
    "custom/notification": {
    	"tooltip": true,
    	"format": "{icon}",
    	"format-icons": {
    	     "notification": "ΎΓλ<span color='#FF8542'><small><sup>έυν</sup></small></span>",
    	     "none": "ΎΓλ",
    	     "dnd-notification": "ΎΘ╖<span foreground='red'><small><sup>έυν</sup></small></span>",
    	     "dnd-none": "ΎΘ╖"
    	},
    	"return-type": "json",
    	"exec-if": "which swaync-client",
    	"exec": "swaync-client -swb",
    	"on-click": "swaync-client -t",
    	"on-click-right": "swaync-client -d -sw",
    	"escape": true
   }
}
